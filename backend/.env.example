# Gemini API Key (from aistudio.google.com or Vertex AI)
GOOGLE_API_KEY=your-gemini-api-key

# GCP Project (for Vertex AI / Imagen 4)
GOOGLE_CLOUD_PROJECT=scrappylabs

# Model override (default: gemini-2.5-flash-preview-native-audio-dialog)
# GRIMDM_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# ScrappyLabs API for NPC voices (default: https://api.scrappylabs.ai)
# SL_API_URL=https://api.scrappylabs.ai
